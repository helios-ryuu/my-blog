# Supabase public reads
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key

# Server-only key used by CMS writes
SUPABASE_SECRET_KEY=your-secret-key

# Public site URL used by metadata and share cards
NEXT_PUBLIC_SITE_URL=http://localhost:3456

# Single admin account
ADMIN_USERNAME=admin
ADMIN_DISPLAY_NAME=Helios

# Use ADMIN_PASSWORD for local development, or ADMIN_PASSWORD_HASH in production.
ADMIN_PASSWORD=change-me
# ADMIN_PASSWORD_HASH=

# Generate a long random value for production.
SESSION_SECRET=change-this-to-a-long-random-secret

# Cloudflare R2 S3 credentials. R2_ENDPOINT may include the bucket suffix.
R2_ENDPOINT=https://account-id.r2.cloudflarestorage.com
R2_BUCKET_NAME=my-blog
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key

# Optional custom domain. Leave empty to use the private /api/media/* proxy.
R2_PUBLIC_URL=https://bucket-blog.helios.id.vn
